PORT=8765
HOST_URL=http://localhost:8765
FRONTEND_URL=http://localhost:3000

# RunPod generator endpoint. Downloader is optional when you only use generation.
RUNPOD_API_KEY=
RUNPOD_GENERATOR_ID=
RUNPOD_DOWNLOADER_ID=
RUNPOD_WEBHOOK_URL=http://localhost:8765/api/v1/webhooks/runpod
MODEL_IMAGE_RUNPOD_BUILD_POLLING=true

# Preferred production model install path. If set, model installs queue a Docker
# image rebuild where the model is downloaded as its own cacheable image layer.
# Use provider=github to trigger .github/workflows/model-image-rebuild.yml through
# GitHub repository_dispatch. GitHub only creates the model migration release;
# RunPod's GitHub integration should build the Docker image from that release.
# Use MODEL_IMAGE_REBUILD_WEBHOOK_URL only for a custom builder.
MODEL_IMAGE_REBUILD_PROVIDER=github
MODEL_IMAGE_REBUILD_GITHUB_REPOSITORY=
MODEL_IMAGE_REBUILD_GITHUB_TOKEN=
MODEL_IMAGE_REBUILD_WEBHOOK_URL=
MODEL_IMAGE_REBUILD_WEBHOOK_TOKEN=
MODEL_IMAGE_WEBHOOK_TOKEN=

# S3-compatible object storage. Cloudflare R2 works well.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET_URL=
R2_BUCKET_NAME=

# Optional Civitai/Gemini integrations.
CIVITAI_API_TOKEN=
GOOGLE_API_KEY=

# Optional posting integrations.
ONE_CLIENT_ID=
ONE_CLIENT_SECRET=
TWO_CLIENT_ID=
TWO_CLIENT_SECRET=
