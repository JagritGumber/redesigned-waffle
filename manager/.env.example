PORT=8765
HOST_URL=http://localhost:8765
FRONTEND_URL=http://localhost:3000

# RunPod generator endpoint. Downloader is optional when you only use generation.
RUNPOD_API_KEY=
RUNPOD_GENERATOR_ID=
RUNPOD_DOWNLOADER_ID=
RUNPOD_WEBHOOK_URL=http://localhost:8765/api/v1/webhooks/runpod
MODEL_IMAGE_RUNPOD_BUILD_POLLING=true

# Preferred production model install path. Point this at a private deploy mirror
# that RunPod watches. Model installs commit cacheable migrations to that private
# repo and push it, so the public repo never receives model metadata.
MODEL_IMAGE_REBUILD_PROVIDER=mirror
MODEL_IMAGE_REBUILD_MIRROR_PATH=
MODEL_IMAGE_REBUILD_MIRROR_REMOTE=origin
MODEL_IMAGE_REBUILD_MIRROR_BRANCH=main
MODEL_IMAGE_REBUILD_MIRROR_PUSH=true

# Optional GitHub provider for private repos or non-sensitive installs only.
# It commits model migration metadata and creates model release tags in GitHub.
MODEL_IMAGE_REBUILD_ALLOW_GITHUB_METADATA=false
MODEL_IMAGE_REBUILD_GITHUB_REPOSITORY=
MODEL_IMAGE_REBUILD_GITHUB_TOKEN=
MODEL_IMAGE_WEBHOOK_TOKEN=

# S3-compatible object storage. Cloudflare R2 works well.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET_URL=
R2_BUCKET_NAME=

# Optional Civitai/Gemini integrations.
CIVITAI_API_TOKEN=
GOOGLE_API_KEY=

# Optional posting integrations.
ONE_CLIENT_ID=
ONE_CLIENT_SECRET=
TWO_CLIENT_ID=
TWO_CLIENT_SECRET=
